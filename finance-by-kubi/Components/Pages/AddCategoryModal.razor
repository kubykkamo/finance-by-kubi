@using finance_by_kubi.Models

@using finance_by_kubi.Data;
@inject IJSRuntime JSRuntime
@inject AppDbContext _context
@using Microsoft.EntityFrameworkCore;

<div class="modal fade" id="categoryModal" data-bs-backdrop="static" data-bs-keyboard="false" tabindex="-1" aria-labelledby="categoryModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h1 class="modal-title fs-5" id="categoryModalLabel">Nová kategorie</h1>
                <button type="button" class="btn-close" @onclick="CloseModal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div class="mb-3">
                    <label for="InputCategoryName" class="form-label">Název</label>
                    <input type="text" class="form-control" id="InputCategoryName" @bind="NewCategoryName">
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="CloseModal">Zavřít</button>
                <button type="button" class="btn btn-success" @onclick='() => AddCategory(1)' >Přidat</button>
                </div>
            </div>
        </div>
    </div>

@code {
    // 1. Tímto přijímáme data (účet) z hlavní stránky
    [Parameter]
    public Account AccountData { get; set; }

    // 2. Tímto dáváme hlavní stránce vědět, že je hotovo
    [Parameter]
    public EventCallback<string> OnCategoryAdded { get; set; }
    [Parameter]
    public EventCallback<string> OnCategoryFailed { get; set; }
    private string NewCategoryName = "";


    // Veřejná metoda, aby šel modal otevřít zvenku
    public async Task OpenModal()
    {
        await JSRuntime.InvokeVoidAsync("showBootstrapModal", "categoryModal");
    }

    private async Task CloseModal()
    {
        await JSRuntime.InvokeVoidAsync("hideBootstrapModal", "categoryModal");
    }

    public async Task AddCategory( int accountId)
    {
        // 1. Ověření existence účtu (VŽDY jako první)
        var accountExists = _context.Accounts.Any(a => a.Id == accountId);

        if (string.IsNullOrWhiteSpace(NewCategoryName))
        {
            await OnCategoryFailed.InvokeAsync("Kategorie musí mít jméno!");
            return;
        }
        if (!accountExists)
        {
            // Tady se rozhodni: vyhodit výjimku, nebo vypsat chybu
            await OnCategoryFailed.InvokeAsync($"Chyba: Účet s ID {accountId} neexistuje!");
        }

        // 2. Vytvoření nového objektu
        var newCategory = new Category
        {
            Name = NewCategoryName,
            AccountId = accountId // Stačí přiřadit jen ID, EF si to přebere
        };

        NewCategoryName = "";

        // 3. Uložení
        try
        {
            _context.Categories.Add(newCategory);
            await _context.SaveChangesAsync();
            await OnCategoryAdded.InvokeAsync("Kategorie přidána!");
        }
        catch (Exception ex)
        {
            
            await OnCategoryFailed.InvokeAsync($"Průšvih: {ex.InnerException?.Message ?? ex.Message}");
        }
       
        }
    }
