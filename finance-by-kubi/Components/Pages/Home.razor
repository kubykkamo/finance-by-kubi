@page "/"
@* Tohle říká stránce, kde najde tvoje třídy *@
@using finance_by_kubi.Models
@using finance_by_kubi.Services

<PageTitle>Přehled - Finance by </PageTitle>

<h2>Můj přehled</h2>

<button class="btn btn-primary mb-3" @onclick="NewTransaction">
    <span class="bi bi-plus-lg me-2"></span> Nová platba
</button>




@if (_account == null)
{
    <p>Načítám data...</p>
}
else
{
   


    <div class="alert alert-info fs-5">
        Celkový zůstatek: <strong>@_account.Balance Kč</strong>
        Celková útrata: <strong>@_account.TotalOutcome Kč </strong>
    </div>

    @* Všimni si těch CSS tříd (table, table-striped) – to je Bootstrap, který to obarví za tebe *@
    <table class="table table-striped table-hover mt-2">
        <thead class="table-dark">
            <tr>
                <th @onclick='() => SortTable("Datum")'>Datum</th>
                <th @onclick='() => SortTable("Popis")'>Popis</th>
                <th>Kategorie</th>
                <th class="text-end" @onclick='() => SortTable("Částka")'>Částka</th>
            </tr>
        </thead>
        <tbody>
            @* Tohle je ta magie! Obyčejný C# foreach cyklus přímo v HTML *@
            @foreach (var t in _account.Transactions)
            {
                <tr>
                    <td>@t.Date.ToShortDateString()</td>
                    <td>@t.Description</td>
                    <td><span class="badge bg-secondary">@t.CategoryName</span></td>
                    @* Tady dynamicky měníme barvu (červená/zelená) podle toho, jestli je to příjem *@
                    <td class="text-end @(t.IsIncome ? "text-success fw-bold" : "text-danger")">
                        @(t.IsIncome ? "+" : "-") @t.Amount Kč
                    </td>
                </tr>
            }
        </tbody>
    </table>
       
    @if (addingTransaction)
    {
        <div class="modal d-block slide-in-left tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
            <div class="modal-dialog modal-dialog">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title">Přidat novou platbu</h5>
                        <button type="button" class="btn-close" @onclick="CloseNewTransaction"></button>
                    </div>
                    <div class="modal-body">
                        <form>
                            <div class="mb-3">
                                <label for="InputDescription" class="form-label">Popis</label>
                                <input type="text" class="form-control" id="InputDescription" @bind="NewDescription">
                            </div>
                            <div class="mb-3">
                                <label for="InputAmount" class="form-label">Částka</label>
                                <input type="number" id ="InputAmount" class="form-control" @bind="NewAmount">
                                <div id="amountHelp" class="form-text">Zadej pouze částku bez měny.</div>
                            </div>  
                            <select class="form-select mb-3" aria-label="Default select example" @bind="selectedCategory" >
                                <option selected>--- Vybrat kategorii ---</option>
                                
                                @foreach (var c in _account.Categories)
                                {
                                    <option>@c.Name</option>
                                }
                                
                            </select>
                            
                            <div class="mb-3 form-check">
                                <input type="checkbox" class="form-check-input" id="exampleCheck1" @bind="IsIncome">
                                <label class="form-check-label" for="exampleCheck1">Je to příjem?</label>
                                <div id="incomeHelp" class="form-text">Zaškrtni, pokud se jedná o příjem.</div>
                            </div>
                        </form>
     
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" @onclick="CloseNewTransaction">Zrušit</button>
                        <button type="button" class="btn btn-success" @onclick="VerifyTransaction">Uložit</button>
                    </div>
                </div>
            </div>
        </div>
    }
    @if (showToast)
    {
        <div class="toast show slide-in-right position-fixed top-0 end-0 m-3 @(isSuccess ? "text-bg-success" : "text-bg-danger")  border-0 shadow" style="z-index: 1055;">
            <div class="d-flex">
                <div class="toast-body fs-6">
                    <span class="bi bi-check-circle me-2"></span> @toastMessage
                </div>
                <button type="button" class="btn-close btn-close-white me-2 m-auto" @onclick="CloseToast"></button>
            </div>
        </div>
    }
}

@code {
    // Tady začíná čistý C#
    private Account? _account;
    List<Transaction> loadedTransactions;
    List<Category> loadedCategories;
    List<Transaction> tableTransactions;
    FileStorageService _storage = new FileStorageService();

    // TRANSACTION
    private string NewDescription = "";
    private decimal NewAmount = 0;
    private bool IsIncome = false;
    private bool addingTransaction = false;
    private string selectedCategory = "";
    //
    // TOAST
    private bool isSuccess;
    private string toastMessage = "";
    private bool showToast = false;
    //

    private async Task VerifyTransaction()
    {


        Category category = _account.Categories
            .FirstOrDefault(c => c.Name == selectedCategory);

        if (category == null)
        {
            await ShowToast("Neplatná kategorie!", false);
            return;
        }


        if (category != null)
        {
            try
            {
                var t = new Transaction(NewDescription, NewAmount, IsIncome, category);
                _account.Transactions.Add(t);
                _storage.SaveTransactions(_account.Transactions);
                await ShowToast("Platba byla úspešně uložena.", true);
                CloseNewTransaction();
            }

            catch (ArgumentException ex)
            {
                await ShowToast(ex.Message, false);
            }
        }
    }
    private void NewTransaction()
    {
        addingTransaction = true;   
    }

    private void SortTable(string HeaderName)
    {
        var transactions = _account.Transactions.ToList();

        switch (HeaderName)
        {
            case("Datum"): transactions.OrderByDescending(t => t.Date)
            .ToList();

                break;
            case("Popis"): transactions.OrderByDescending(t => t.Description)
            .ToList();
                break;
            case ("Částka"):
                _account.Transactions.Reverse();
                

                break;
            default:
                break;
        }

        _account.Transactions.Reverse();

   




    }

    private void CloseNewTransaction()
    {
        addingTransaction = false;    
    }

    private void CloseToast()
    {
        showToast = false;
    }

    private async Task ShowToast(string message, bool succ)
    {

        toastMessage = message;
        isSuccess = succ;
        showToast = true;
        StateHasChanged();

        await Task.Delay(3000);

        showToast = false;
        StateHasChanged();


    }

    // Tato metoda se spustí sama hned při načtení stránky
    protected override void OnInitialized()
    {

        // 1. Založíme testovací kategorie
       
        
       
        loadedCategories = _storage.LoadCategories();
        loadedTransactions = _storage.LoadTransactions() 
        .OrderByDescending(t => t.Date)
        .ToList();
        

        
        // 2. Vytvoříme účet (přesně jak jsi to měl ve WinForms)
        _account = new Account(loadedTransactions, loadedCategories);

        // 3. Vygenerujeme testovací data, abychom měli na co koukat
        
    }

    private void GenerateTestData()
    {
        var random = new Random();
        for (int i = 0; i < 100; i++)
        {
            var cat = _account.Categories[random.Next(_account.Categories.Count)];
            bool isIncome = random.Next(0, 2) == 0;
            decimal amount = random.Next(50, 2000);
            
            // Využíváme tvůj konstruktor s ochranou proti prázdnému popisu
            var t = new Transaction($"Testovací nákup {i + 1}", amount, isIncome, cat);
            t.Date = DateTime.Now.AddDays(-random.Next(0, 30));
            
            _account.Transactions.Add(t);
        }
    }
}